{
  "name": "emerald-vscode",
  "displayName": "Emerald",
  "description": "Emerald programming language support for VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "emerald",
      "aliases": ["Emerald", "emerald"],
      "extensions": [".em"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "emerald",
      "scopeName": "source.emerald",
      "path": "./syntaxes/emerald.tmLanguage.json"
    }],
    "configuration": {
      "type": "object",
      "title": "Emerald",
      "properties": {
        "emerald.maxNumberOfProblems": {
          "scope": "resource",
          "type": "number",
          "default": 100,
          "description": "Controls the maximum number of problems produced by the server."
        },
        "emerald.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:emerald"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.2.0",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "eslint": "^8.47.0",
    "mocha": "^10.1.0",
    "typescript": "^5.1.6"
  }
}