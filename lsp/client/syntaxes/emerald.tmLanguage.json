{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Emerald",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.emerald",
          "match": "//.*$"
        },
        {
          "name": "comment.block.emerald",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.emerald",
          "match": "\\b(if|else|for|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.emerald",
          "match": "\\b(function|let|extern|mut|const|import|export)\\b"
        },
        {
          "name": "keyword.type.emerald",
          "match": "\\b(i32|i64|f32|f64|bool|string|void)\\b"
        },
        {
          "name": "keyword.other.emerald",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.emerald",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.emerald",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.emerald",
          "match": "\\b\\d+\\b"
        },
        {
          "name": "constant.numeric.float.emerald",
          "match": "\\b\\d+\\.\\d+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.emerald",
          "match": "\\bfunction\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\("
        },
        {
          "name": "entity.name.function.call.emerald",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\("
        }
      ]
    },
    "variables": {
      "name": "variable.other.emerald",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.emerald",
          "match": "[+\\-*/%=<>!&|^~]"
        },
        {
          "name": "keyword.operator.assignment.emerald",
          "match": "[+\\-*/]?="
        }
      ]
    }
  },
  "scopeName": "source.emerald"
}